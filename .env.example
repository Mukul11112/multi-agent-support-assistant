# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values:   cp .env.example .env
# The system runs with NO changes at all (mock LLM + in-memory DB), which is
# useful for a first run. Set LLM_PROVIDER for real answers.
# ---------------------------------------------------------------------------

# --- LLM -------------------------------------------------------------------
# groq | openai | gemini | ollama | mock
# Recommended: groq. Free tier, fast, runs Llama 3.3 70B. Key: console.groq.com
LLM_PROVIDER=mock
LLM_MODEL=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700

GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Embeddings / RAG ------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=4
# Cosine similarity floor. Below this, the agent escalates instead of guessing.
RETRIEVAL_MIN_SCORE=0.25

# --- Database --------------------------------------------------------------
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB=techmart_support

# --- Auth ------------------------------------------------------------------
# Generate a real one:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRY_MINUTES=1440

# --- App -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
MEMORY_TURNS=6
